# Minimal Render deployment — copy these into Render's environment variable settings.
# Server vars → Render Web Service (Settings → Environment)
# Client vars → Render Static Site (Settings → Environment)
#
# Fill in each value as you work through render_deployment_guide.md.
# Do NOT commit a filled-in copy of this file.

# ---------------------------------------------------------------
# SERVER VARS  (template/app/.env.server for local dev)
# ---------------------------------------------------------------

# Render PostgreSQL — use the Internal Database URL from the Render DB info page
# Step 5a
DATABASE_URL=

# Generate with: openssl rand -hex 32
# Step 6
JWT_SECRET=

# Your Render Web Service URL (e.g. https://myapp-server.onrender.com)
# Step 5b
WASP_SERVER_URL=

# Your Render Static Site URL (e.g. https://myapp-client.onrender.com)
# Step 5c
CLIENT_URL=

# Stripe — test keys to start, swap for live keys in Step 10
# Step 2c
STRIPE_API_KEY=

# Step 7 — set after creating the webhook endpoint
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — one per plan, from Step 2b
PAYMENTS_HOBBY_SUBSCRIPTION_PLAN_ID=
PAYMENTS_PRO_SUBSCRIPTION_PLAN_ID=
PAYMENTS_CREDITS_10_PLAN_ID=

# Comma-separated list of emails that get admin access on signup
# Step 6
ADMIN_EMAILS=

# SendGrid API key (SG.xxx...) — from Step 1a
# Skip if you disabled email verification or are using Gmail SMTP instead
SENDGRID_API_KEY=

# Gmail SMTP — alternative to SendGrid, fill these in instead if using Gmail
# Step 1a (Gmail SMTP option)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=

# OpenAI — required for the AI demo app
# Step 6
OPENAI_API_KEY=

# ---------------------------------------------------------------
# CLIENT VARS  (template/app/.env.client for local dev)
# ---------------------------------------------------------------

# Must match WASP_SERVER_URL above — baked in at build time
# Step 5c
REACT_APP_API_URL=
